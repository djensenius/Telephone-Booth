{
  "annotations": { "list": [] },
  "description": "Audio levels and operator HTTP health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "booth_audio_peak_amplitude{booth_id=~\"$booth\",channel=\"input\"}",
          "legendFormat": "input peak {{booth_id}}",
          "refId": "A"
        },
        {
          "expr": "booth_audio_peak_amplitude{booth_id=~\"$booth\",channel=\"output\"}",
          "legendFormat": "output peak {{booth_id}}",
          "refId": "B"
        },
        {
          "expr": "booth_audio_rms_amplitude{booth_id=~\"$booth\",channel=\"input\"}",
          "legendFormat": "input rms {{booth_id}}",
          "refId": "C"
        },
        {
          "expr": "booth_audio_rms_amplitude{booth_id=~\"$booth\",channel=\"output\"}",
          "legendFormat": "output rms {{booth_id}}",
          "refId": "D"
        }
      ],
      "title": "Audio levels (linear amplitude, peak & rms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "rate(booth_operator_requests_total{booth_id=~\"$booth\"}[5m])",
          "legendFormat": "{{route}} {{status_class}}",
          "refId": "A"
        }
      ],
      "title": "Operator HTTP rate by status class",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(booth_operator_request_duration_seconds_bucket{booth_id=~\"$booth\"}[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        }
      ],
      "title": "Operator request duration p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (source, booth_id) (rate(booth_errors_total{booth_id=~\"$booth\"}[5m]))",
          "legendFormat": "{{source}} {{booth_id}}",
          "refId": "A"
        }
      ],
      "title": "Booth errors per second by source",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["booth", "audio"],
  "templating": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "definition": "label_values(booth_info, booth_id)",
        "label": "Booth",
        "name": "booth",
        "options": [],
        "query": "label_values(booth_info, booth_id)",
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Booth — Audio & operator HTTP",
  "uid": "booth-audio",
  "version": 1,
  "weekStart": ""
}
