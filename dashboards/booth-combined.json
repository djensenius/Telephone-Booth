              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": {
                      "name": "${datasource}"
                    },
                    "spec": {
                      "editorMode": "code",
                      "expr": "booth_cpu_temperature_celsius{booth_id=~\"$booth\"}",
                      "instant": false,
                      "range": true,
                      "legendFormat": "{{booth_id}}"
                    }
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "",
        "id": 1,
        "links": [],
        "title": "CPU temperature",
        "vizConfig": {
          "kind": "VizConfig",
          "group": "stat",
          "version": "12.0.0",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "thresholds"
                },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": 0
                    },
                    {
                      "color": "yellow",
                      "value": 70
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                },
                "unit": "celsius"
              },
              "overrides": []
            },
            "options": {
              "colorMode": "value",
              "graphMode": "area",
              "justifyMode": "auto",
              "reduceOptions": {
                "calcs": [
                  "lastNotNull"
                ],
                "fields": "",
                "values": false
              }
            }
          }
        }
