# Environment file for the telephone-booth-vmagent service.
#
# Edit this file (or override via debconf during install) to point vmagent
# at your VictoriaMetrics remote_write endpoint. Reload the unit with
# `systemctl restart telephone-booth-vmagent` after editing.
#
# The remote_write URL is the only required setting. Auth material lives
# in /etc/phone-booth/vmagent-token (mode 0600).
BOOTH_VM_REMOTE_WRITE_URL=https://victoriametrics.example/api/v1/write
